# Copy to .env.local for local overrides, or set these in the Vercel dashboard.

# Public URL where the /data directory is served.
# Dev default (unset): /data — Vite serves public/data from disk.
# Prod on Vercel: set to your Cloudflare R2 custom domain.
# Example: VITE_DATA_BASE=https://data.oceanhealth.example.com
VITE_DATA_BASE=

# Mapbox public token (pk.*). Required.
# Get one at https://account.mapbox.com/access-tokens/
# In production, restrict it by URL to your domain.
VITE_MAPBOX_TOKEN=
